{
  "mcpServers": {
    "vizor-moveit": {
      "_comment": "Vizor MoveIt MCP verification feedback server",
      "command": "uv",
      "cwd": "${workspaceFolder}/server",
      "args": [
        "run",
        "python",
        "-m",
        "moveit_mcp",
        "--rosbridge-host",
        "localhost",
        "--rosbridge-port",
        "9090"
      ]
    }
  }
}
